# ── Hyperliquid ──────────────────────────────────────────────────────────
HYPERLIQUID_PRIVATE_KEY=0x...          # Agent wallet private key (signer only)
HYPERLIQUID_VAULT_ADDRESS=0x...        # Main wallet address (holds funds)
HYPERLIQUID_NETWORK=mainnet            # mainnet or testnet

# ── Anthropic Claude API ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-haiku-4-5-20251001
MAX_TOKENS=4096

# ── Runtime ──────────────────────────────────────────────────────────────
ASSETS=BTC ETH                         # Space-separated list of assets to trade
INTERVAL=1h                            # Outer loop interval
APP_PORT=3000                          # Dashboard HTTP port

# ── Score system — THREE SEPARATE KEYS, never merge ──────────────────────
MIN_TRADE_SCORE=3        # 0-5 int — entry_confirmed() internal gate in strategy.py
MIN_SIGNAL_SCORE=7       # 0-10 float — main loop execution pre-gate
MIN_AI_SCORE=7           # 0-10 float — Claude analysis trigger (raise to 8 to reduce AI calls)

# ── Execution controls ────────────────────────────────────────────────────
TAKER_FEE_PCT=0.00045    # 0.045% per side (Hyperliquid taker fee)
COOLDOWN_MINUTES=60      # Block asset N minutes after SL hit
MAX_DAILY_TRADES=10      # Hard cap: max executed trades per UTC calendar day
MAX_TRADE_HOURS=12       # Force-close any trade open longer than this

# ── Risk parameters ───────────────────────────────────────────────────────
MAX_POSITION_PCT=15
MAX_LEVERAGE=5
MAX_LOSS_PER_POSITION_PCT=8
MAX_TOTAL_EXPOSURE_PCT=50
DAILY_LOSS_CIRCUIT_BREAKER_PCT=12
MANDATORY_SL_PCT=3
MAX_CONCURRENT_POSITIONS=2
MIN_BALANCE_RESERVE_PCT=20

# ── AI analysis controls ──────────────────────────────────────────────────
NEWS_FETCH_ENABLED=true              # Toggle macro RSS fetching (false for testnet/offline)
AI_MAX_TOKENS=4000                   # Max output tokens for Claude market analysis
AI_APPROVE_CACHE_MINUTES=60         # Minutes an APPROVE verdict stays cached
AI_REJECT_CACHE_MINUTES=30          # Minutes a REJECT verdict stays cached
CONFLUENCE_REQUIRE_30M=true         # Require 30m timeframe in confluence gate
AI_STALE_TF_MINUTES=55              # Max age of higher-TF data before AI blocked on inner ticks
MIN_AI_CALL_GAP_MINUTES=30          # Hard minimum gap between Claude calls per asset
ADX_HALF_SIZE_THRESHOLD=20          # ADX below this AND score < 9 → position size halved
