# Environments — never commit secrets
.env
.env.*
!.env.example

# Python artifacts
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
*.egg

# Virtual environments
.venv/
venv/
env/

# Editors / OS
.DS_Store
.idea/
.vscode/
Thumbs.db

# Caches / type checkers
.pytest_cache/
.mypy_cache/
.cache/
.ruff_cache/

# Runtime log files (grow unbounded, not useful in git)
*.log
nohup.out

# Runtime data files (generated at runtime, not source)
diary.jsonl
decisions.jsonl
prompts.log
state.json
state.json.tmp
risk_state.json
risk_state.json.tmp

# Private notes — local only, not for server or GitHub
DEVNOTES.md
STRATEGY.md

# Node artifacts (not a Node project — safe to ignore)
package-lock.json
node_modules/